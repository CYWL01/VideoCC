<Window x:Class="SubtitleMatcher.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="视频字幕自动匹配工具-许可" Height="660" Width="780"
        Icon="SubtitleMatcher.ico"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F2F5"
        FontFamily="Microsoft YaHei UI, Segoe UI Emoji, Segoe UI"
        FontSize="14">
    <Window.Resources>
        <!-- 通用卡片 -->
        <Style x:Key="LicenseCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- 区段标题（条形色块） -->
        <Style x:Key="SectionHeader" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- 条目（图标+文字） -->
        <Style x:Key="BulletText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题区 -->
        <Border Grid.Row="0" Background="#ECEFF1" CornerRadius="6" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="视频字幕自动匹配工具" FontSize="22" FontWeight="Bold" Foreground="#263238"/>
                    <TextBlock FontSize="13" Foreground="#546E7A" Margin="0,6,0,0">
                        <Run Text="许可协议"/>
                        <Run Text="·" Foreground="#B0BEC5"/>
                        <Run Text="Copyright © 2026 CYWL01"/>
                    </TextBlock>
                </StackPanel>
                <Border Grid.Column="1" Background="#4CAF50" CornerRadius="4" Padding="10,4" VerticalAlignment="Center">
                    <TextBlock Text="个人免费使用 · 禁止商业收费"
                               Foreground="White" FontSize="12" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <!-- 内容滚动区 -->
        <ScrollViewer x:Name="OuterScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,12,0">
            <StackPanel>

                <!-- 一句话总览 -->
                <Border Style="{StaticResource LicenseCard}" Background="#FFFDE7" BorderBrush="#FFE082">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="📌" FontSize="20" VerticalAlignment="Top" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Style="{StaticResource BulletText}" FontSize="13.5" FontWeight="Bold" Foreground="#E65100" Text="一句话总览：" Margin="0,0,0,8"/>
                            <TextBlock Style="{StaticResource BulletText}" FontSize="13.5" Margin="0,0,0,4">
                                <Run Text="✅ "/><Run Text="个人可"/><Run Text="自由使用、修改、分享" FontWeight="Bold" Foreground="#2E7D32"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource BulletText}" FontSize="13.5" Margin="0,0,0,4">
                                <Run Text="❌ "/><Run Text="禁止以任何形式收费" FontWeight="Bold" Foreground="#C62828"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource BulletText}" FontSize="13.5">
                                <Run Text="📋 "/><Run Text="分享时须保留项目名「视频字幕自动匹配工具」与作者署名「CYWL01」。"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 软件说明 -->
                <Border Style="{StaticResource LicenseCard}">
                    <StackPanel>
                        <Border Style="{StaticResource SectionHeader}" Background="#1565C0">
                            <TextBlock Style="{StaticResource SectionHeaderText}" Text="📖 软件说明"/>
                        </Border>
                        <TextBlock Style="{StaticResource BulletText}">
                            <Run Text="• "/><Run Text="纯离线影音辅助工具，全程由 AI 辅助编写完成。"/>
                            <LineBreak/>
                            <Run Text="• "/><Run Text="无专业商业开发资质，"/><Run Text="非商业正式商用软件" FontWeight="Bold"/><Run Text="。"/>
                            <LineBreak/>
                            <Run Text="• "/><Run Text="仅面向"/><Run Text="个人日常休闲" FontWeight="Bold" Foreground="#1565C0"/><Run Text="、影音整理场景"/><Run Text="免费使用" FontWeight="Bold" Foreground="#1565C0"/><Run Text="。"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ✅ 允许做的事 -->
                <Border Style="{StaticResource LicenseCard}" BorderBrush="#A5D6A7">
                    <StackPanel>
                        <Border Style="{StaticResource SectionHeader}" Background="#2E7D32">
                            <TextBlock Style="{StaticResource SectionHeaderText}" Text="✅ 允许做的事"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Style="{StaticResource BulletText}" Margin="0,0,0,6">
                                <Run Text="① "/><Run Text="免费下载、安装、运行、本地使用" FontWeight="Bold" Foreground="#2E7D32"/>
                                <LineBreak/>
                                <Run Text="    无功能限制、无激活要求、无使用时长限制。" Foreground="#607D8B"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource BulletText}" Margin="0,0,0,6">
                                <Run Text="② "/><Run Text="二次修改、界面调整、功能精简、结构优化" FontWeight="Bold" Foreground="#2E7D32"/>
                                <LineBreak/>
                                <Run Text="    修改后可自行闭源留存，无需公开源代码。" Foreground="#607D8B"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource BulletText}" Margin="0,0,0,6">
                                <Run Text="③ "/><Run Text="无偿转发、分享、传播" FontWeight="Bold" Foreground="#2E7D32"/>
                                <LineBreak/>
                                <Run Text="    原版与衍生版均可，免费分享行为不受限制。" Foreground="#607D8B"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource BulletText}">
                                <Run Text="④ "/><Run Text="整合到其他软件或商业软件中" FontWeight="Bold" Foreground="#2E7D32"/>
                                <LineBreak/>
                                <Run Text="    但字幕匹配功能必须向最终用户免费开放。" Foreground="#607D8B"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ❌ 严禁做的事 -->
                <Border Style="{StaticResource LicenseCard}" BorderBrush="#EF9A9A" Background="#FFF8F8">
                    <StackPanel>
                        <Border Style="{StaticResource SectionHeader}" Background="#C62828">
                            <TextBlock Style="{StaticResource SectionHeaderText}" Text="❌ 严禁做的事"/>
                        </Border>
                        <TextBlock Style="{StaticResource BulletText}" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#B71C1C">
                            严禁对本软件或字幕匹配功能进行任何形式的盈利性收费：
                        </TextBlock>
                        <Grid Margin="6,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource BulletText}"><Run Text="• "/>售卖出售</TextBlock>
                                <TextBlock Style="{StaticResource BulletText}"><Run Text="• "/>付费打包</TextBlock>
                                <TextBlock Style="{StaticResource BulletText}"><Run Text="• "/>网盘收费</TextBlock>
                                <TextBlock Style="{StaticResource BulletText}"><Run Text="• "/>有偿代装</TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource BulletText}"><Run Text="• "/>有偿定制</TextBlock>
                                <TextBlock Style="{StaticResource BulletText}"><Run Text="• "/>商业引流收费</TextBlock>
                                <TextBlock Style="{StaticResource BulletText}"><Run Text="• "/>平台付费上架</TextBlock>
                                <TextBlock Style="{StaticResource BulletText}"><Run Text="• "/>付费会员/插件/模块</TextBlock>
                            </StackPanel>
                        </Grid>
                        <TextBlock Style="{StaticResource BulletText}" Margin="0,8,0,0">
                            <Run Text="• "/><Run Text="篡改作者信息" FontWeight="Bold" Foreground="#C62828"/><Run Text="、冒充原创、冒充官方版本。"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ⚠️ 免责声明 -->
                <Border Style="{StaticResource LicenseCard}" BorderBrush="#FFCC80">
                    <StackPanel>
                        <Border Style="{StaticResource SectionHeader}" Background="#EF6C00">
                            <TextBlock Style="{StaticResource SectionHeaderText}" Text="⚠️ 免责声明"/>
                        </Border>
                        <TextBlock Style="{StaticResource BulletText}" Margin="0,0,0,4">
                            <Run Text="① "/><Run Text="AI 辅助开发，"/><Run Text="不承诺绝对稳定" FontWeight="Bold"/><Run Text="，无官方售后维护服务。"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource BulletText}" Margin="0,0,0,4">
                            <Run Text="② "/><Run Text="使用过程中产生的设备、文件、数据、网络异常，"/><Run Text="由使用者自行承担" FontWeight="Bold" Foreground="#EF6C00"/><Run Text="。"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource BulletText}" Margin="0,0,0,4">
                            <Run Text="③ "/><Run Text="仅限合规合法影音辅助用途，"/><Run Text="违规使用后果自负" FontWeight="Bold" Foreground="#EF6C00"/><Run Text="。"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource BulletText}">
                            <Run Text="④ "/><Run Text="一经下载、安装、使用，即代表"/><Run Text="完全认同并遵守以上全部条款" FontWeight="Bold"/><Run Text="。"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 完整原文 -->
                <Expander Header="📄 查看完整许可原文" FontSize="13" Foreground="#455A64"
                          Margin="0,0,0,4" IsExpanded="False">
                    <Border Style="{StaticResource LicenseCard}" Margin="0,8,0,0">
                        <FlowDocumentScrollViewer x:Name="LicenseDocumentViewer"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  IsToolBarVisible="False"
                                                  Background="White"
                                                  MinHeight="320"
                                                  Padding="10"
                                                  PreviewMouseWheel="OnLicenseViewerPreviewMouseWheel"/>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="关闭" Width="100" Height="35" Margin="0,12,0,0"
                HorizontalAlignment="Right" Click="Close_Click"
                Background="#607D8B" Foreground="White" FontWeight="Bold"
                BorderThickness="0"/>
    </Grid>
</Window>
