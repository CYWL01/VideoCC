<Window x:Class="SubtitleMatcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:SubtitleMatcher.Models"
        Title="VideoCC 视频字幕匹配" Height="650" Width="1040"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource UiFont}"
        FontSize="14"
        AllowDrop="True">

    <Window.Resources>
        <!-- ═══ 工具栏按钮样式 ═══ -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1Fffffff"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolBtnActive" BasedOn="{StaticResource ToolBtn}" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryHoverBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ToolBtnPrimary" BasedOn="{StaticResource ToolBtn}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ToolPrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ToolBtnOff" BasedOn="{StaticResource ToolBtn}" TargetType="Button">
            <Setter Property="Background" Value="#33c8c8c8"/>
            <Setter Property="Foreground" Value="#80ffffff"/>
        </Style>

        <!-- ═══ 浏览按钮 ═══ -->
        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ 执行/撤销按钮 ═══ -->
        <Style x:Key="ExecBtn" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UndoBtn" TargetType="Button">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ 小清空按钮 ═══ -->
        <Style x:Key="SmallClearBtn" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Width="20" Height="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#20E88383"/>
                                <Setter Property="Foreground" Value="{StaticResource ToolPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ 集数徽标 ═══ -->

        <DataTemplate x:Key="MatchRowTemplate">
            <Grid>
                <!-- 略，在窗口加载时用代码设置 Columns -->
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <!-- ═══════════════ 整体布局 ═══════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 顶部工具栏 -->
            <RowDefinition Height="*"/>      <!-- 主体 -->
        </Grid.RowDefinitions>

        <!-- ═══ 顶部工具栏（居中 + 分组） ═══ -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="4,2">
            <Viewbox Stretch="Uniform" MaxHeight="72" StretchDirection="Both">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- 分组1：辅助 + 配色 -->
                <StackPanel Orientation="Horizontal" Margin="4,4">
                    <Button Style="{StaticResource ToolBtn}" Content="📖 说明" x:Name="HelpBtn"/>
                    <Button Style="{StaticResource ToolBtn}" Content="ℹ️ 许可" x:Name="AboutBtn"/>
                    <Button Style="{StaticResource ToolBtn}" Content="⚙️ 配置" x:Name="ConfigBtn"/>
                </StackPanel>

                <Rectangle Width="2" Fill="#59ffffff" Margin="12,4" VerticalAlignment="Stretch"/>

                <!-- 分组2：操作模式 -->
                <StackPanel Orientation="Horizontal" Margin="4,4">
                    <Button Style="{StaticResource ToolBtnActive}" Content="📋 复制" x:Name="CopyModeBtn"/>
                    <Button Style="{StaticResource ToolBtn}" Content="📦 移动" x:Name="MoveModeBtn"/>
                    <Button Style="{StaticResource ToolBtn}" Content="✏️ 重命名" x:Name="RenameModeBtn"/>
                </StackPanel>

                <Rectangle Width="2" Fill="#59ffffff" Margin="12,4" VerticalAlignment="Stretch"/>

                <!-- 分组3：操作 -->
                <StackPanel Orientation="Horizontal" Margin="4,4">
                    <Button Style="{StaticResource ToolBtn}" Content="🤖 AI 规则" x:Name="AiRulesBtn"/>
                    <Button Style="{StaticResource ToolBtnOff}" Content="🤖 AI 关" x:Name="AiToggleBtn"/>
                    <Button Style="{StaticResource ToolBtnPrimary}" Content="🔍 扫描" x:Name="ScanBtn"/>
                </StackPanel>
                </StackPanel>
            </Viewbox>
        </Border>

        <!-- ═══ 主体（Grid 双行布局：设置区固定 + 结果区可滚动） ═══ -->
        <Grid Grid.Row="1" Margin="12,8,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══ 设置卡片 ═══ -->
            <Border Grid.Row="0" Background="{StaticResource CardBgBrush}"
                    CornerRadius="8" Padding="12,12"
                    Margin="0,0,0,8"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 路径输入区 -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="2"
                            CornerRadius="6" Padding="8,8" Margin="0,0,0,8">
                        <StackPanel>
                            <!-- 视频行 -->
                            <Border BorderThickness="1" BorderBrush="Transparent"
                                    CornerRadius="6" Padding="4" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="📹" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="视频" FontSize="12"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Grid Grid.Column="2">
                                        <Border BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="4"
                                                Background="{StaticResource InputBgBrush}">
                                            <TextBox x:Name="VideoPathBox"
                                                     FontSize="12" Padding="8,4"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     AllowDrop="True"
                                                     PreviewDragOver="PathBox_DragOver"
                                                     Drop="PathBox_Drop"
                                                     TextChanged="PathBox_TextChanged"/>
                                        </Border>
                                        <TextBlock x:Name="VideoDragHint"
                                                   Text="📂 拖拽文件夹到此处"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   IsHitTestVisible="False"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                    <Button Grid.Column="3" Style="{StaticResource BrowseBtn}"
                                            Content="📁 浏览" Margin="4,0,4,0" x:Name="BrowseVideoBtn"/>
                                    <Button Grid.Column="4" Style="{StaticResource SmallClearBtn}"
                                            Content="✕" x:Name="ClearVideoBtn"
                                            ToolTip="清空视频路径"/>
                                </Grid>
                            </Border>

                            <!-- 字幕行 -->
                            <Border BorderThickness="1" BorderBrush="Transparent"
                                    CornerRadius="6" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="📝" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="字幕" FontSize="12"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Grid Grid.Column="2">
                                        <Border BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="4"
                                                Background="{StaticResource InputBgBrush}">
                                            <TextBox x:Name="SubtitlePathBox"
                                                     FontSize="12" Padding="8,4"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     AllowDrop="True"
                                                     PreviewDragOver="PathBox_DragOver"
                                                     Drop="PathBox_Drop"
                                                     TextChanged="PathBox_TextChanged"/>
                                        </Border>
                                        <TextBlock x:Name="SubtitleDragHint"
                                                   Text="📂 拖拽文件夹到此处"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   IsHitTestVisible="False"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                    <Button Grid.Column="3" Style="{StaticResource BrowseBtn}"
                                            Content="📁 浏览" Margin="4,0,4,0" x:Name="BrowseSubBtn"/>
                                    <Button Grid.Column="4" Style="{StaticResource SmallClearBtn}"
                                            Content="✕" x:Name="ClearSubBtn"
                                            ToolTip="清空字幕路径"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 底部：全部信息居中，按钮靠右 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 全部状态信息合并居中 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" x:Name="StatusPills">
                                <TextBlock FontSize="11" Foreground="{StaticResource TextLightBrush}"
                                           Margin="0,0,8,0">
                                    <Run Text="📺 视频 "/><Run FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="0"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextLightBrush}"
                                           Margin="0,0,8,0">
                                    <Run Text="📝 字幕 "/><Run FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="0"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextLightBrush}"
                                           Margin="0,0,8,0">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessTextBrush}"
                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <Run Text="匹配 "/><Run FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" x:Name="MatchCount" Text="0"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextLightBrush}"
                                           Margin="0,0,8,0">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource WarnTextBrush}"
                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <Run Text="未匹配 "/><Run FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" x:Name="UnmatchCount" Text="0"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                           Text="0ms" x:Name="ScanTimeText"/>
                            </StackPanel>
                            <TextBlock FontSize="11" Foreground="{StaticResource TextBrush}"
                                       IsHitTestVisible="False" Margin="8,0,4,0">
                                <Run Text="│ "/>
                                <Run Text="✓ "/>
                                <Run FontWeight="SemiBold" x:Name="SelectedCount" Text="0"/>
                                <Run Text=" / "/>
                                <Run FontWeight="SemiBold" x:Name="TotalCount" Text="0"/>
                            </TextBlock>
                            <!-- 就绪（状态通过 pills 显示） -->
                            <ProgressBar x:Name="ProgressBar"
                                         Width="100" Height="4"
                                         Minimum="0" Maximum="100" Value="0"
                                         Foreground="{StaticResource PrimaryBrush}"
                                         Background="{StaticResource ProgressBarBgBrush}"
                                         BorderThickness="0" Margin="4,0"
                                         VerticalAlignment="Center"
                                         Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- 右侧：操作按钮 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource ExecBtn}"
                                    Content="▶️ 执行" x:Name="ExecuteBtn"
                                    Margin="4,0"/>
                            <Button Style="{StaticResource UndoBtn}"
                                    Content="↩️ 撤销" x:Name="UndoBtn"
                                    Margin="4,0"/>
                            <Button Style="{StaticResource UndoBtn}"
                                    Content="🗑️ 清空" x:Name="ClearAllBtn"
                                    Margin="4,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══ 结果卡片（* 高度，DataGrid 内部滚动） ═══ -->
            <Border Grid.Row="1" Background="{StaticResource CardBgBrush}"
                    CornerRadius="8"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tabs -->
                    <Grid Grid.Row="0" Background="{StaticResource HeaderBgBrush}" Margin="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" x:Name="AutoTabBg" CornerRadius="6,6,0,0"
                                Background="Transparent" Padding="0">
                            <Button x:Name="AutoTabBtn"
                                    Content="⚡ 自动匹配"
                                    Background="Transparent" BorderThickness="0"
                                    FontSize="12" FontWeight="Bold"
                                    Foreground="{StaticResource PrimaryHoverBrush}"
                                    Padding="14,10" Cursor="Hand"/>
                        </Border>
                        <Border Grid.Column="1" x:Name="ManualTabBg" CornerRadius="6,6,0,0"
                                Background="Transparent" Padding="0">
                            <Button x:Name="ManualTabBtn"
                                    Content="🔧 手动匹配"
                                    Background="Transparent" BorderThickness="0"
                                    FontSize="12" Foreground="{StaticResource TextLightBrush}"
                                    Padding="14,10" Cursor="Hand"/>
                        </Border>
                    </Grid>

                    <!-- DataGrid（使用 * 高度，受限后可自行滚动） -->
                    <DataGrid Grid.Row="1" x:Name="MatchGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              RowHeaderWidth="0"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderThickness="0"
                              FontSize="12"
                              Foreground="{StaticResource TextBrush}"

                              AlternatingRowBackground="{StaticResource TableAltBrush}"
                              LoadingRow="MatchGrid_LoadingRow">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="Padding" Value="10,4"/>
                                <Setter Property="Height" Value="28"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="{StaticResource TableAltBrush}"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsSuspected}" Value="True">
                                        <Setter Property="Background" Value="#FFF8E1"/>
                                        <Setter Property="ToolTip" Value="疑似匹配 — AI 认为可能同一作品但置信度较低"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
