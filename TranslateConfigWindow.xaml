<Window x:Class="SubtitleMatcher.TranslateConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="翻译服务配置 - 视频字幕自动匹配工具" Height="680" Width="780"
        Icon="SubtitleMatcher.ico"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="#FAFAFA"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="14">
    <Window.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Border Grid.Row="0" Background="#E3F2FD" CornerRadius="6" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="翻译服务配置" FontSize="20" FontWeight="Bold" Foreground="#1565C0"/>
                <TextBlock Text="配置在线翻译服务的服务器地址，用于将不同语言的剧名翻译成英文后再匹配" FontSize="12" Foreground="#546E7A" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 当前状态 -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="当前状态" FontSize="15" FontWeight="Bold" Foreground="#263238" Margin="0,0,0,8"/>
                        <Border Background="#F5F5F5" CornerRadius="4" Padding="10">
                            <StackPanel>
                                <WrapPanel Margin="0,0,0,4">
                                    <TextBlock Text="翻译功能：" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StatusText" Text="已开启" Foreground="#4CAF50" FontWeight="Bold" Margin="4,0,0,0"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <TextBlock Text="当前 API 地址：" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="EndpointText" Text="默认服务器" Foreground="#1565C0" Margin="4,0,0,0" TextWrapping="Wrap"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- API 设置 -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="自定义 API 服务器" FontSize="15" FontWeight="Bold" Foreground="#263238" Margin="0,0,0,6"/>
                        <TextBlock Text="如果你有自己的翻译服务器，可以在下方填入服务器地址。留空则使用默认的免费服务器。" FontSize="12" Foreground="#757575" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <TextBlock Text="API 地址" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="EndpointTextBox" Padding="8,6" FontSize="13"
                                 BorderBrush="#BDBDBD" BorderThickness="1"/>
                        <TextBlock Text="示例：https://libretranslate.de/translate" FontSize="11" Foreground="#9E9E9E" Margin="0,4,0,0"/>

                        <WrapPanel Margin="0,12,0,0">
                            <Button Content="保存" Click="Save_Click" Width="90" Height="34"
                                    Background="#4CAF50" Foreground="White" FontWeight="Bold"
                                    BorderThickness="0" Margin="0,0,8,0"/>
                            <Button Content="恢复默认" Click="Reset_Click" Width="90" Height="34"
                                    Background="#FF9800" Foreground="White" FontWeight="Bold"
                                    BorderThickness="0" Margin="0,0,8,0"/>
                            <Button x:Name="TestButton" Content="测试连接" Click="Test_Click" Width="90" Height="34"
                                    Background="#2196F3" Foreground="White" FontWeight="Bold"
                                    BorderThickness="0"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- 详细说明 -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="详细说明（逐步操作指南）" FontSize="15" FontWeight="Bold" Foreground="#263238" Margin="0,0,0,8"/>

                        <Border Background="#FFF3E0" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="什么是翻译 API？" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,6" FontSize="13"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="0,0,0,6">
翻译 API 就像一个翻译员。当你的视频文件名是中文、日文或韩文，而字幕文件名是英文时，软件需要把剧名翻译成英文才能比较它们是不是同一部剧。
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20">
这个翻译功能需要一个「翻译服务器」来帮它做翻译工作。本软件内置两个免费服务器地址，你也可以填写自己的服务器。
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#E8F5E9" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="默认情况（不需要任何操作）" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,6" FontSize="13"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="0,0,0,6">
软件出厂时已经自带了两个免费的翻译服务器地址：
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">• https://libretranslate.de</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,6">• https://translate.faucet.dev</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="0,0,0,6">
大多数情况下你什么都不用做。只要点击主界面上的「🌐 翻译关」按钮切换成「🌐 翻译开」即可使用。
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20">
如果默认服务器暂时不可用，你才需要填入自定义的服务器地址。
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#E3F2FD" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="如何自己搭建免费翻译服务器？（有难度的方案）" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,6" FontSize="13"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="0,0,0,8">
这是一个开源的免费翻译项目。如果你有动手能力，可以自己搭建专属翻译服务器。
                                </TextBlock>

                                <TextBlock Text="第一步：下载项目" FontWeight="SemiBold" Foreground="#1565C0" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">1. 打开浏览器，访问 https://github.com/LibreTranslate/LibreTranslate</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">2. 点击绿色的「Code」按钮，选择「Download ZIP」</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,6">3. 下载后解压到电脑上的一个文件夹</TextBlock>

                                <TextBlock Text="第二步：安装 Python" FontWeight="SemiBold" Foreground="#1565C0" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,6">4. 如果你没有 Python，先去 https://www.python.org/downloads/ 下载并安装（安装时勾选「Add Python to PATH」选项）</TextBlock>

                                <TextBlock Text="第三步：安装翻译服务" FontWeight="SemiBold" Foreground="#1565C0" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">5. 打开「命令提示符」（按 Win+R，输入 cmd，回车）</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">6. 输入 cd 空格和你解压的文件夹路径（例如 cd C:\LibreTranslate-main），回车</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,6">7. 输入 pip install libretranslate，回车（等待安装完成，可能需要几分钟）</TextBlock>

                                <TextBlock Text="第四步：启动服务器" FontWeight="SemiBold" Foreground="#1565C0" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">8. 输入 libretranslate --host 0.0.0.0 --port 5000，回车</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">9. 看到提示信息后，说明服务器启动成功</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">10. 在本窗口的输入框中填入 http://localhost:5000/translate</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,0">11. 点击「保存」即可使用</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFF8E1" CornerRadius="4" Padding="12" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="使用第三方公共翻译服务" FontWeight="Bold" Foreground="#F57F17" Margin="0,0,0,6" FontSize="13"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="0,0,0,6">
你也可以搜索网上的 LibreTranslate 公共服务器（可能随时变更）：
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">• https://libretranslate.de/translate（默认之一）</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">• https://translate.faucet.dev/translate（默认之二）</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">• https://translate.argosopentech.com/translate</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,6">• https://lt.vern.cc/translate</TextBlock>

                                <TextBlock Text="使用方法" FontWeight="SemiBold" Foreground="#F57F17" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">1. 在上面的输入框中填入完整的 API 地址（必须以 https:// 开头，以 /translate 结尾）</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">2. 点击「保存」按钮</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,6">3. 点击「测试连接」检查是否可用</TextBlock>

                                <TextBlock Text="注意事项" FontWeight="SemiBold" Foreground="#C62828" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">• 公共服务器可能有访问频率限制，如果人多的时候翻译可能会慢</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,2">• 如果你的网络无法访问国外网站，建议自己搭建本地服务器</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20" Margin="12,0,0,0">• 如果翻译失败，软件会自动跳过翻译，不影响普通的匹配功能</TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="关闭" Width="100" Height="35" Margin="0,12,0,0"
                HorizontalAlignment="Right" Click="Close_Click"
                Background="#607D8B" Foreground="White" FontWeight="Bold"
                BorderThickness="0"/>
    </Grid>
</Window>
