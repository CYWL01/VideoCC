<Window x:Class="SubtitleMatcher.AiConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 配置" Height="580" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource UiFont}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                          CanContentScroll="False" PanningMode="VerticalOnly">
            <StackPanel>

        <!-- 顶部说明 -->
        <TextBlock Text="填入 AI 信息即可使用，支持 OpenAI 兼容 API"
                   FontSize="12" Foreground="{StaticResource TextLightBrush}" Margin="0,0,0,12"/>

        <!-- ═══ API 地址 ═══ -->
        <StackPanel Margin="0,0,0,8">
            <TextBlock Text="API 地址" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="ApiUrlBox" FontSize="12" Padding="8,4"
                         BorderThickness="0"
                         Text="https://api.openai.com/v1/chat/completions"/>
            </Border>
        </StackPanel>

        <!-- ═══ API Key ═══ -->
        <StackPanel Margin="0,0,0,8">
            <TextBlock Text="API Key" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <PasswordBox x:Name="ApiKeyBox" FontSize="12" Padding="8,4"
                             BorderThickness="0"/>
            </Border>
            <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0">
                <Run Text="本地模型（Ollama / LM Studio）通常"/><Run FontWeight="Bold" Text="不需要 Key"/><Run Text="，留空即可"/>
            </TextBlock>
        </StackPanel>

        <!-- ═══ 模型名称 ═══ -->
        <StackPanel Margin="0,0,0,8">
            <TextBlock Text="模型名称" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="ModelBox" FontSize="12" Padding="8,4"
                         BorderThickness="0" Text="gpt-4o-mini"/>
            </Border>
            <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"
                       TextWrapping="Wrap">
                <Run Text="本地模型如 "/><Run FontFamily="Consolas" FontSize="11" Text="qwen2.5:7b"/><Run Text="、"/><Run FontFamily="Consolas" FontSize="11" Text="llama3.2:3b"/>
            </TextBlock>
        </StackPanel>

        <!-- ═══ 本地 Ollama 示例（可选中复制） ═══ -->
        <Border Background="#1E2A35" CornerRadius="8" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontSize="11" Foreground="#8AB4F8" FontWeight="Bold"
                           Text="💻 本地 Ollama 配置示例" Margin="12,10,12,4"/>
                <FlowDocumentScrollViewer Grid.Row="1"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          IsToolBarVisible="False"
                                          VerticalScrollBarVisibility="Hidden"
                                          Padding="12,0,12,10">
                    <FlowDocument PagePadding="0" FontFamily="Consolas" FontSize="11"
                                  Foreground="#E8E8E8" LineHeight="18">
                        <Paragraph Margin="0">
                            <Run Foreground="#888" Text="# 终端执行"/><LineBreak/>
                            <Run Foreground="#7BC8A4" Text="$ "/><Run Text="ollama pull qwen2.5:7b"/><LineBreak/>
                            <Run Foreground="#7BC8A4" Text="$ "/><Run Text="ollama serve"/><LineBreak/>
                            <Run Foreground="#888" Text=""/><LineBreak/>
                            <Run Foreground="#888" Text="# 填入工具"/><LineBreak/>
                            <Run Text="API 地址 → "/><Run Foreground="#FFD54F" Text="http://localhost:11434/v1/chat/completions"/><LineBreak/>
                            <Run Text="API Key  → "/><Run Foreground="#FFD54F" Text="（留空）"/><LineBreak/>
                            <Run Text="模型名称 → "/><Run Foreground="#FFD54F" Text="qwen2.5:7b"/>
                        </Paragraph>
                    </FlowDocument>
                </FlowDocumentScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ 常见 API 配置参考 ═══ -->
        <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
            <StackPanel>

                <TextBlock Text="📚 常见 API 配置参考" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>

                <!-- OpenAI 官方 -->
                <Border Background="White" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                    <FlowDocumentScrollViewer BorderThickness="0" Background="Transparent"
                                              IsToolBarVisible="False" VerticalScrollBarVisibility="Hidden"
                                              Padding="0">
                        <FlowDocument PagePadding="0" FontSize="11" Foreground="{StaticResource TextBrush}">
                            <Paragraph Margin="0" LineHeight="20">
                                <Run FontWeight="SemiBold" Text="🤖 OpenAI" FontSize="12"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="API "/><Run Text="https://api.openai.com/v1/chat/completions"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="Key "/><Run Foreground="{StaticResource WarnTextBrush}" Text="需要"/><Run Text=" ｜ "/><Run Foreground="{StaticResource TextMutedBrush}" Text="模型 "/><Run Text="gpt-4o-mini / gpt-4o"/><LineBreak/>
                                <Run Foreground="{StaticResource SuccessTextBrush}" Text="推荐云端首选，适合没有本地 GPU 的用户"/>
                            </Paragraph>
                        </FlowDocument>
                    </FlowDocumentScrollViewer>
                </Border>

                <!-- 火山引擎 -->
                <Border Background="White" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                    <FlowDocumentScrollViewer BorderThickness="0" Background="Transparent"
                                              IsToolBarVisible="False" VerticalScrollBarVisibility="Hidden"
                                              Padding="0">
                        <FlowDocument PagePadding="0" FontSize="11" Foreground="{StaticResource TextBrush}">
                            <Paragraph Margin="0" LineHeight="20">
                                <Run FontWeight="SemiBold" Text="🌋 火山引擎（豆包）" FontSize="12"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="API "/><Run Text="https://ark.cn-beijing.volces.com/api/v3/chat/completions"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="Key "/><Run Foreground="{StaticResource WarnTextBrush}" Text="需要"/><Run Text=" ｜ "/><Run Foreground="{StaticResource TextMutedBrush}" Text="模型 "/><Run Text="ep-xxxxx（推理端点 ID）"/><LineBreak/>
                                <Run Foreground="{StaticResource SuccessTextBrush}" Text="国内直连速度快，注册送额度"/>
                            </Paragraph>
                        </FlowDocument>
                    </FlowDocumentScrollViewer>
                </Border>

                <!-- DeepSeek -->
                <Border Background="White" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                    <FlowDocumentScrollViewer BorderThickness="0" Background="Transparent"
                                              IsToolBarVisible="False" VerticalScrollBarVisibility="Hidden"
                                              Padding="0">
                        <FlowDocument PagePadding="0" FontSize="11" Foreground="{StaticResource TextBrush}">
                            <Paragraph Margin="0" LineHeight="20">
                                <Run FontWeight="SemiBold" Text="🧠 DeepSeek" FontSize="12"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="API "/><Run Text="https://api.deepseek.com/v1/chat/completions"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="Key "/><Run Foreground="{StaticResource WarnTextBrush}" Text="需要"/><Run Text=" ｜ "/><Run Foreground="{StaticResource TextMutedBrush}" Text="模型 "/><Run Text="deepseek-chat"/><LineBreak/>
                                <Run Foreground="{StaticResource SuccessTextBrush}" Text="性价比极高，适合大批量判断"/>
                            </Paragraph>
                        </FlowDocument>
                    </FlowDocumentScrollViewer>
                </Border>

                <!-- Ollama 本地 -->
                <Border Background="White" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                    <FlowDocumentScrollViewer BorderThickness="0" Background="Transparent"
                                              IsToolBarVisible="False" VerticalScrollBarVisibility="Hidden"
                                              Padding="0">
                        <FlowDocument PagePadding="0" FontSize="11" Foreground="{StaticResource TextBrush}">
                            <Paragraph Margin="0" LineHeight="20">
                                <Run FontWeight="SemiBold" Text="🖥️ Ollama（本地推荐）" FontSize="12"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="API "/><Run Text="http://localhost:11434/v1/chat/completions"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="Key "/><Run Foreground="{StaticResource SuccessTextBrush}" Text="不需要"/><Run Text=" ｜ "/><Run Foreground="{StaticResource TextMutedBrush}" Text="模型 "/><Run Text="qwen2.5:7b / llama3.2:3b"/><LineBreak/>
                                <Run Foreground="{StaticResource SuccessTextBrush}" Text="完全免费，数据不离开本地，需安装 Ollama"/>
                            </Paragraph>
                        </FlowDocument>
                    </FlowDocumentScrollViewer>
                </Border>

                <!-- LM Studio -->
                <Border Background="White" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                    <FlowDocumentScrollViewer BorderThickness="0" Background="Transparent"
                                              IsToolBarVisible="False" VerticalScrollBarVisibility="Hidden"
                                              Padding="0">
                        <FlowDocument PagePadding="0" FontSize="11" Foreground="{StaticResource TextBrush}">
                            <Paragraph Margin="0" LineHeight="20">
                                <Run FontWeight="SemiBold" Text="🖥️ LM Studio" FontSize="12"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="API "/><Run Text="http://localhost:1234/v1/chat/completions"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="Key "/><Run Foreground="{StaticResource SuccessTextBrush}" Text="不需要"/><Run Text=" ｜ "/><Run Foreground="{StaticResource TextMutedBrush}" Text="模型 "/><Run Text="llama-3.2-3b-instruct（加载的模型名）"/><LineBreak/>
                                <Run Foreground="{StaticResource SuccessTextBrush}" Text="免费，有图形界面，适合不想敲命令的用户"/>
                            </Paragraph>
                        </FlowDocument>
                    </FlowDocumentScrollViewer>
                </Border>

                <!-- 通义千问 -->
                <Border Background="White" CornerRadius="6" Padding="10,8">
                    <FlowDocumentScrollViewer BorderThickness="0" Background="Transparent"
                                              IsToolBarVisible="False" VerticalScrollBarVisibility="Hidden"
                                              Padding="0">
                        <FlowDocument PagePadding="0" FontSize="11" Foreground="{StaticResource TextBrush}">
                            <Paragraph Margin="0" LineHeight="20">
                                <Run FontWeight="SemiBold" Text="☁️ 通义千问（阿里云）" FontSize="12"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="API "/><Run Text="https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions"/><LineBreak/>
                                <Run Foreground="{StaticResource TextMutedBrush}" Text="Key "/><Run Foreground="{StaticResource WarnTextBrush}" Text="需要"/><Run Text=" ｜ "/><Run Foreground="{StaticResource TextMutedBrush}" Text="模型 "/><Run Text="qwen-plus / qwen-max"/><LineBreak/>
                                <Run Foreground="{StaticResource SuccessTextBrush}" Text="国内直连，阿里云用户免额外注册"/>
                            </Paragraph>
                        </FlowDocument>
                    </FlowDocumentScrollViewer>
                </Border>

            </StackPanel>
        </Border>

        <!-- ═══ 测试连接 ═══ -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="TestBtn" Content="🔍 测试连接" Padding="12,6" FontSize="12"
                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                    Background="{StaticResource CardBgBrush}" Cursor="Hand"
                    Click="TestBtn_Click"/>
            <TextBlock x:Name="TestResult" FontSize="11" VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
        </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ 分隔线 ═══ -->
        <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource BorderBrush}" Margin="0,4,0,12"/>

        <!-- ═══ 保存 / 取消 ═══ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存" Padding="20,8" FontSize="12" FontWeight="Bold"
                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                    Click="SaveBtn_Click"/>
            <Button Content="取消" Padding="20,8" FontSize="12"
                    Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" Cursor="Hand"
                    Click="CancelBtn_Click"/>
            <Button Content="🔄 清空" Padding="12,8" FontSize="12"
                    Background="Transparent" BorderBrush="{StaticResource WarnTextBrush}"
                    Foreground="{StaticResource WarnTextBrush}"
                    BorderThickness="1" Cursor="Hand" Margin="8,0,0,0"
                    Click="ClearBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
