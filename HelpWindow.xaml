<Window x:Class="SubtitleMatcher.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="视频字幕自动匹配工具-说明文档" Height="700" Width="850"
        Icon="SubtitleMatcher.ico"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F2F5">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 页面切换按钮 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="TabSimpleButton" Content="📄 简洁" Width="90" Height="32"
                    Click="TabSimple_Click" Margin="0,0,6,0"
                    Background="#1565C0" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="TabDetailButton" Content="📖 详细" Width="90" Height="32"
                    Click="TabDetail_Click" Margin="0,0,6,0"
                    Background="#E0E0E0" Foreground="#616161" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="TabFaqButton" Content="❓ 常见问题" Width="110" Height="32"
                    Click="TabFaq_Click" Margin="0,0,6,0"
                    Background="#E0E0E0" Foreground="#616161" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="TabExamplesButton" Content="📋 示例" Width="90" Height="32"
                    Click="TabExamples_Click"
                    Background="#E0E0E0" Foreground="#616161" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="1" CornerRadius="5" Padding="10">
            <FlowDocumentScrollViewer x:Name="HelpDocumentViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      IsToolBarVisible="False"
                                      Background="White"
                                      Focusable="False"/>
        </Border>

        <Button Grid.Row="2" Content="关闭" Width="100" Height="35" Margin="0,12,0,0"
                HorizontalAlignment="Right" Click="Close_Click"
                Background="#1565C0" Foreground="White" FontWeight="Bold"
                BorderThickness="0"/>
    </Grid>
</Window>
