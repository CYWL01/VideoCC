<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════ 三套配色方案 ═══════════════ -->

    <!-- 方案 1: 薄荷茶色（默认） -->
    <!-- 方案 2: 晴空淡蓝 -->
    <!-- 方案 3: 暖阳珊瑚 -->

    <!-- 默认使用方案 1 的色值 -->
    <Color x:Key="ColorBg">#F0F7F3</Color>
    <Color x:Key="ColorCardBg">#FFFFFF</Color>
    <Color x:Key="ColorPrimary">#7BC8A4</Color>
    <Color x:Key="ColorPrimaryHover">#5FB88E</Color>
    <Color x:Key="ColorPrimaryLight">#E8F5E9</Color>
    <Color x:Key="ColorHeaderBg">#EDF7F1</Color>
    <Color x:Key="ColorTableAlt">#F8FBF9</Color>
    <Color x:Key="ColorText">#3D4F4A</Color>
    <Color x:Key="ColorTextLight">#8A9E96</Color>
    <Color x:Key="ColorTextMuted">#B5C7BF</Color>
    <Color x:Key="ColorBorder">#DCE8E0</Color>
    <Color x:Key="ColorSuccessBg">#E8F5E9</Color>
    <Color x:Key="ColorSuccessText">#2E7D32</Color>
    <Color x:Key="ColorWarnBg">#FFF8E1</Color>
    <Color x:Key="ColorWarnText">#E65100</Color>

    <!-- SolidBrush -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource ColorBg}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource ColorCardBg}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource ColorPrimaryHover}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource ColorPrimaryLight}"/>
    <SolidColorBrush x:Key="HeaderBgBrush" Color="{StaticResource ColorHeaderBg}"/>
    <SolidColorBrush x:Key="TableAltBrush" Color="{StaticResource ColorTableAlt}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource ColorText}"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource ColorTextLight}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="SuccessBgBrush" Color="{StaticResource ColorSuccessBg}"/>
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource ColorSuccessText}"/>
    <SolidColorBrush x:Key="WarnBgBrush" Color="{StaticResource ColorWarnBg}"/>
    <SolidColorBrush x:Key="WarnTextBrush" Color="{StaticResource ColorWarnText}"/>

    <!-- ═══ 工具栏配色 ═══ -->
    <Color x:Key="ColorToolPrimary">#E88383</Color>
    <Color x:Key="ColorToolPrimaryHover">#D46A6A</Color>
    <Color x:Key="ColorInputBg">#FAFCFA</Color>
    <Color x:Key="ColorProgressBarBg">#E8ECE8</Color>
    <SolidColorBrush x:Key="ToolPrimaryBrush" Color="{StaticResource ColorToolPrimary}"/>
    <SolidColorBrush x:Key="ToolPrimaryHoverBrush" Color="{StaticResource ColorToolPrimaryHover}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource ColorInputBg}"/>
    <SolidColorBrush x:Key="ProgressBarBgBrush" Color="{StaticResource ColorProgressBarBg}"/>

    <FontFamily x:Key="UiFont">Microsoft YaHei UI, Segoe UI Emoji, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Consolas, Courier New</FontFamily>

    <!-- 卡片阴影 -->
    <DropShadowEffect x:Key="CardShadow" ShadowDepth="1" BlurRadius="4" Opacity="0.08" Direction="270"/>

    <!-- ═══════════════ 主题调色板（仅保留薄荷茶色） ═══════════════ -->
    <x:Array x:Key="ThemePalette1" Type="Color" x:Shared="False">
        <Color>#F0F7F3</Color> <Color>#FFFFFF</Color> <Color>#7BC8A4</Color>
        <Color>#5FB88E</Color> <Color>#E8F5E9</Color> <Color>#EDF7F1</Color>
        <Color>#F8FBF9</Color> <Color>#3D4F4A</Color> <Color>#8A9E96</Color>
        <Color>#B5C7BF</Color> <Color>#DCE8E0</Color> <Color>#E8F5E9</Color>
        <Color>#2E7D32</Color> <Color>#FFF8E1</Color> <Color>#E65100</Color>
    </x:Array>
</ResourceDictionary>
